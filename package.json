{
  "name": "agent-harness-blueprint",
  "version": "1.0.0",
  "private": true,
  "description": "Beginner harness engineering course with VS Code Copilot support",
  "type": "module",
  "bin": {
    "harness-score": "scorecard/bin/harness-score.js"
  },
  "scripts": {
    "docs:dev": "vitepress dev docs",
